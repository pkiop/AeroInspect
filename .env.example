# --- Gemini Developer API (기본 백엔드) ---
GEMINI_API_KEY=your-api-key-here

# --- Vertex AI 전환 (선택) — 아래 3개를 설정하면 Vertex 백엔드로 동작 ---
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- 모델 재정의 (선택) ---
# AEROINSPECT_VISION_MODEL=gemini-3.1-pro
# AEROINSPECT_VISION_FALLBACK_MODEL=gemini-3.5-flash
# AEROINSPECT_GROUNDING_MODEL=gemini-3.5-flash
# AEROINSPECT_REPORT_MODEL=gemini-3.5-flash

# --- 파이프라인 파라미터 (선택) ---
# AEROINSPECT_CONFIDENCE_THRESHOLD=0.6
# AEROINSPECT_REQUEST_TIMEOUT_MS=120000

# --- File Search 스토어 (scripts/setup_file_search.py 실행 시 자동 기록) ---
# AEROINSPECT_FILE_SEARCH_STORE=fileSearchStores/xxxxxxxx
